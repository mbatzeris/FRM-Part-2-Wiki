# Source PDFs (large files, should not be in version control)
raw/*.pdf
wiki/**/*.pdf

# Extracted book text (derived from PDFs, can be regenerated)
wiki/**/*.txt

# Extracted/temporary files in raw/
raw/extracted_*.txt
raw/toc*.txt
raw/*timestamp*.pdf

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/

# IDE
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~

# Windows shortcuts (machine-specific)
*.lnk

# OS
.DS_Store
Thumbs.db

# Temporary directories
temp/
cache/
tmp/

# Logs
*.log

# Graphify generated artifacts (regeneratable from source via /graphify)
graphify-out/
