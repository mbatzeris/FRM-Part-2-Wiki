# Source PDFs (large files, should not be in version control)
raw/*.pdf
wiki/**/*.pdf

# Extracted book text (derived from PDFs, can be regenerated)
wiki/**/*.txt

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# Virtual environments
venv/
env/
ENV/
.venv-gemini/

# Secrets
.env

# Generated extraction artefacts (regeneratable)
out/
**/*.gemini.md

# IDE
.vscode/
.idea/
.obsidian/
*.swp
*.swo
*~

# Windows shortcuts (machine-specific)
*.lnk

# OS
.DS_Store
Thumbs.db

# Temporary directories
temp/
cache/
tmp/

# Logs
*.log
